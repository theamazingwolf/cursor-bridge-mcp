{
  "name": "cursor-bridge-mcp",
  "version": "0.1.0",
  "description": "MCP server that bridges Cursor's context ecosystem (rules, agents, skills) to Claude Code and other MCP-compatible tools",
  "type": "module",
  "bin": {
    "cursor-bridge-mcp": "dist/index.cjs"
  },
  "main": "dist/index.cjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx tsc && node esbuild.config.js",
    "build:check": "tsc --noEmit",
    "prepare": "npm run build",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "cursor",
    "claude-code",
    "context",
    "rules"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theamazingwolf/cursor-bridge-mcp.git"
  },
  "homepage": "https://github.com/theamazingwolf/cursor-bridge-mcp#readme",
  "bugs": {
    "url": "https://github.com/theamazingwolf/cursor-bridge-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/node": "^22.15.3",
    "esbuild": "^0.27.4",
    "minimatch": "^10.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "yaml": "^2.7.1"
  }
}
